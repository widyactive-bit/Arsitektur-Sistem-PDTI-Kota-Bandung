                    "200": {
                        "description": "Daftar Riwayat Kehadiran",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/auth/register": {
            "post": {
                "tags": [
                    "Autentikasi"
                ],
                "summary": "Registrasi Pengguna & Atlet Baru",
                "operationId": "c47a1b563e5e8bc3c7b962f893981e84",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "alamat",
                                    "no_hp",
                                    "ktp",
                                    "kk"
                                ],
                                "properties": {
                                    "name": {
                                        "description": "Nama Lengkap",
                                        "type": "string",
                                        "example": "Muhammad Rafli"
                                    },
                                    "email": {
                                        "description": "Email Login",
                                        "type": "string",
                                        "format": "email",
                                        "example": "rafli@psti.bandung.go.id"
                                    },
                                    "password": {
                                        "description": "Kata Sandi",
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    },
                                    "alamat": {
                                        "description": "Alamat Lengkap",
                                        "type": "string",
                                        "example": "Jl. Lombok No. 12, Bandung"
                                    },
                                    "no_hp": {
                                        "description": "No. Handphone",
                                        "type": "string",
                                        "example": "081122334455"
                                    },
                                    "ktp": {
                                        "description": "Scan KTP",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "kk": {
                                        "description": "Scan Kartu Keluarga",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "sertifikat[]": {
                                        "description": "Sertifikat Medali/Penghargaan (Opsional)",
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "format": "binary"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Registrasi Berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Registrasi berhasil. Skuad menunggu persetujuan admin."
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "1|token_hash_here"
                                        },
                                        "user": {
                                            "type": "object"
                                        },
                                        "athlete": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/auth/login": {
            "post": {
                "tags": [
                    "Autentikasi"
                ],
                "summary": "Masuk ke Sistem (Mendapatkan Token Sanctum)",
                "operationId": "1ff9c65c5cd1a8e0786e318eed856972",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "atlet@psti.bandung.go.id"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login Berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token": {
                                            "type": "string",
                                            "example": "1|token_hash_here"
                                        },
                                        "user": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validasi Gagal / Password Salah"
                    }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "tags": [
                    "Autentikasi"
                ],
                "summary": "Keluar dari Sistem (Menghapus Token)",
                "operationId": "eae6a8251a6469bbabe454860f64cf37",
                "responses": {
                    "200": {
                        "description": "Logout Berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Logged out successfully"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/auth/profile": {
            "get": {
                "tags": [
