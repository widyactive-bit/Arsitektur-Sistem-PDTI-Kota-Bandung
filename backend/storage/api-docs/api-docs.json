        "/attendance/checkin": {
            "post": {
                "tags": [
                    "Absensi"
                ],
                "summary": "Absensi Masuk Latihan (Check In)",
                "operationId": "c080dbe95746c52796918e36c5372d99",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "latitude",
                                    "longitude",
                                    "selfie"
                                ],
                                "properties": {
                                    "latitude": {
                                        "type": "number",
                                        "format": "double",
                                        "example": -6.90389
                                    },
                                    "longitude": {
                                        "type": "number",
                                        "format": "double",
                                        "example": 107.61861
                                    },
                                    "selfie": {
                                        "description": "Base64 image or file path",
                                        "type": "string",
                                        "example": "selfie_mock_1.jpg"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Check In Berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Check In successful"
                                        },
                                        "record": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/attendance/checkout": {
            "post": {
                "tags": [
                    "Absensi"
                ],
                "summary": "Absensi Keluar Latihan (Check Out & Hitung Durasi)",
                "operationId": "5b3ed707f9514e23292e3c93dd943d43",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "latitude",
                                    "longitude",
                                    "selfie"
                                ],
                                "properties": {
                                    "latitude": {
                                        "type": "number",
                                        "format": "double",
                                        "example": -6.90389
                                    },
                                    "longitude": {
                                        "type": "number",
                                        "format": "double",
                                        "example": 107.61861
                                    },
                                    "selfie": {
                                        "description": "Base64 image or file path",
                                        "type": "string",
                                        "example": "selfie_checkout_mock.jpg"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Check Out Berhasil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Check Out successful"
                                        },
                                        "duration_minutes": {
                                            "type": "integer",
                                            "example": 150
                                        },
                                        "record": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/attendance/history": {
            "get": {
                "tags": [
