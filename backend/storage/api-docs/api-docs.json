                                            "type": "integer",
                                            "example": 1
                                        },
                                        "name": {
                                            "type": "string",
                                            "example": "Muhammad Rafli"
                                        },
                                        "email": {
                                            "type": "string",
                                            "example": "atlet@psti.bandung.go.id"
                                        },
                                        "role": {
                                            "type": "string",
                                            "example": "Atlet"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/schedules": {
            "get": {
                "tags": [
